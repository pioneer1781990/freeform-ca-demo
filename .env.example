# Copy this file to .env and fill in your values. DO NOT commit .env.
export PROJECT_ID=your-gcp-project-id
export PROJECT_NUMBER=000000000000
export REGION=US
export BQ_LOCATION=US
export GCS_REGION=us-central1
export DATASET=cymbal_retail
export GCS_BUCKET=${PROJECT_ID}-cymbal-retail
export CONNECTION_ID=cymbal-gcs-conn
export CONNECTION_FULL=us.cymbal-gcs-conn
# Fill in from BQ Connection details
export CONNECTION_SA=bqcx-000000000000-xxxx@gcp-sa-bigquery-condel.iam.gserviceaccount.com
# Get from console.anthropic.com → API keys
export ANTHROPIC_API_KEY=sk-ant-api03-...
